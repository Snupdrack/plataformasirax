# ==================== Sirax · Synkdata ====================
# Environment Variables — copy this file to `.env` and adjust values.

# ---------- Database ----------
# SQLite (default, great for development / single-instance deploys)
DATABASE_URL="file:./db/sirax.db"

# PostgreSQL (recommended for production / multi-instance)
# DATABASE_URL="postgresql://sirax:<password>@<host>:5432/sirax?schema=public"

# ---------- Authentication ----------
# 32+ char random string. Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRE="7d"

# ---------- Application ----------
NODE_ENV="production"
PORT=3000
NEXT_PUBLIC_APP_NAME="Sirax"
NEXT_PUBLIC_APP_VENDOR="Synkdata"
NEXT_PUBLIC_APP_URL="https://sirax.example.com"

# ---------- Optional Integrations ----------
# OpenAI / Z-AI for the AI Investigation module
# OPENAI_API_KEY=""
# ZAI_API_KEY=""

# Sanctions lists refresh (cron job)
# SANCTIONS_REFRESH_CRON="0 3 * * *"
