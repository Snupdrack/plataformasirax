# ==================== Sirax · Synkdata ====================
# Environment Variables — copy this file to `.env` and adjust values.
# Las que NO tengan valor de ejemplo son obligatorias para que el modulo
# correspondiente haga consultas reales; si las dejas vacias, ese modulo
# regresa `available: false` con un mensaje explicito en vez de simular datos.

# ---------- Database (PostgreSQL — coincide con docker-compose.yml) ----------
DATABASE_URL="postgresql://sirax:<password>@<host>:5432/sirax?schema=public"

# Para desarrollo local sin Docker puedes usar un Postgres gratuito
# (Railway, Neon, Supabase) o levantar uno local:
#   docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev -e POSTGRES_DB=sirax postgres:16-alpine
# DATABASE_URL="postgresql://postgres:dev@localhost:5432/sirax?schema=public"

# ---------- Authentication ----------
# 32+ char random string. Generate with: openssl rand -base64 48
# Si la dejas vacia en desarrollo, se genera un secreto temporal por proceso
# (los tokens no persisten entre reinicios). En produccion es obligatoria.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRE="7d"

# ---------- Application ----------
NODE_ENV="production"
PORT=3000
NEXT_PUBLIC_APP_NAME="Sirax"
NEXT_PUBLIC_APP_VENDOR="Synkdata"
NEXT_PUBLIC_APP_URL="https://sirax.example.com"

# ==================== Proveedores de datos reales ====================

# ---------- Nubarium (CURP/RENAPO, RFC/SAT, historial IMSS, PEPs) ----------
# Contrata en https://nubarium.com — te da usuario/contraseña por servicio.
# Catalogo verificado: nubarium.com/productos
NUBARIUM_USER=""
NUBARIUM_PASSWORD=""
# Solo tocar si tu Postman collection de Nubarium te da una ruta distinta:
# NUBARIUM_CURP_URL="https://curp.nubarium.com/renapo/v2/valida_curp"
# NUBARIUM_RFC_URL="https://rfc.nubarium.com/sat/v2/valida_rfc"
# NUBARIUM_IMSS_URL="https://api.nubarium.com/imss/v1/historial_laboral"
# NUBARIUM_PEP_URL="https://api.nubarium.com/pld/v1/consulta_pep"

# ---------- OpenSanctions (sanciones OFAC/ONU/EU/UK, complementa el PEP de Nubarium) ----------
# Gratis para uso no comercial: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=""

# ---------- HaveIBeenPwned (brechas de datos del email) ----------
# ~$3.50 USD/mes: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=""

# ---------- Hunter.io (verificacion/entregabilidad de email) ----------
# Tier gratuito 25/mes: https://hunter.io/api-keys
HUNTER_API_KEY=""

# ---------- Numverify (validacion de telefono) ----------
# Tier gratuito 100/mes: https://numverify.com
NUMVERIFY_API_KEY=""

# ---------- Claude API (dictamen ejecutivo con IA real) ----------
# Si la dejas vacia, el reporte usa una plantilla determinística (sigue
# siendo texto real generado desde los datos verificados, solo que sin IA).
# https://console.anthropic.com
ANTHROPIC_API_KEY=""
